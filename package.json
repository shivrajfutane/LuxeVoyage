{
  "name": "ai-trip-planner",
  "version": "1.0.0",
  "scripts": {
    "start": "npx concurrently \"npm run server\" \"npm run client\"",
    "server": "npm run start --prefix backend",
    "client": "npm run dev --prefix frontend",
    "build": "npm install --prefix frontend && npm run build --prefix frontend && cp -r frontend/dist/* ./"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "groq-sdk": "^0.10.0",
    "mongoose": "^8.0.0",
    "google-auth-library": "^9.4.1",
    "nodemailer": "^6.9.7"
  }
}
